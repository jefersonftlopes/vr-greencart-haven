{
  "name": "greencart-haven",
  "private": true,
  "version": "1.0.0",
  "description": "Micro frontend e-commerce de hortifruti — teste técnico VR (Module Federation)",
  "type": "module",
  "scripts": {
    "start": "pnpm -r --parallel --stream start",
    "build": "pnpm -r build",
    "preview": "pnpm -r --parallel --stream preview",
    "test": "pnpm -r --no-bail --workspace-concurrency=1 --filter=!@greencart/types --filter=!@greencart/ui test",
    "test:coverage": "pnpm -r --no-bail --workspace-concurrency=1 --filter=!@greencart/types --filter=!@greencart/ui test:coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "biome format --write --no-errors-on-unmatched"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  }
}
